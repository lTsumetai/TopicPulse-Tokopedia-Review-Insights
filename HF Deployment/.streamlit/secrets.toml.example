# Template only. Copy to secrets.toml (which is gitignored) and fill in real values,
# OR set these under Hugging Face Space -> Settings -> Secrets for deployment.
# NEVER commit the real secrets.toml.

[connections.supabase]
dialect = "postgresql"
host = "YOUR_SUPABASE_HOST"
port = 5432
database = "postgres"
username = "YOUR_USERNAME"
password = "YOUR_PASSWORD"
